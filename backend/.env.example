# ============================================================
# مندوبك Backend - Environment Variables
# انسخ الملف ده لـ .env وحط فيه القيم الحقيقية
# (للتطوير المحلي فقط - في Production استخدم wrangler secrets)
# ============================================================

# === Supabase (مطلوب) ===
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Database ===
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# === Clerk Auth (مطلوب) ===
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# === JWT ===
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# === Resend (للإيميلات - اختياري) ===
RESEND_API_KEY=re_...

# === App Config ===
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=8787

# === Cloudflare (للـ Production على Workers فقط) ===
# هذه القيم تتضاف في wrangler.toml أو عبر: wrangler secret put SECRET_NAME
# CLOUDFLARE_ACCOUNT_ID=
# KV_NAMESPACE_ID=
# R2_BUCKET_NAME=mandoubak-ids
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://your-r2-public-domain.com
