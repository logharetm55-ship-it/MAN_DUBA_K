# ============================================================
# مندوبك - Mandoubak .gitignore
# ============================================================

# === Environment Variables (لا ترفعها أبداً!) ===
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
frontend/.env
frontend/.env.local
frontend/.env.production
backend/.env
backend/.env.local

# === Node Modules ===
node_modules/
frontend/node_modules/
backend/node_modules/

# === Build Outputs ===
dist/
frontend/dist/
backend/dist/
build/
.output/
.vercel/

# === Vite Cache ===
frontend/.vite/
.vite/

# === TypeScript ===
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo
backend/tsconfig.tsbuildinfo

# === Prisma ===
prisma/migrations/dev.db
prisma/migrations/dev.db-journal
*.db
*.db-journal

# === Cloudflare / Wrangler ===
.wrangler/
backend/.wrangler/
wrangler.toml.bak

# === Capacitor / Android ===
frontend/android/
android/
*.apk
*.aab
*.keystore
*.jks

# === IDE & Editors ===
.vscode/
.idea/
*.swp
*.swo
*.suo
.DS_Store
Thumbs.db

# === Logs ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# === Testing ===
coverage/
.nyc_output/

# === Replit-specific ===
.replit
replit.nix
.cache/
.config/
.upm/
zipFile.zip

# === R2 Mock (local only) ===
backend/public/r2-mock/
backend/public/uploads/

# === Misc ===
.agents/
attached_assets/
*.zip
*.tar.gz
