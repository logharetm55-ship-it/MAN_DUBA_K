# ============================================================
# مندوبك Frontend - Environment Variables
# انسخ الملف ده لـ .env.local وحط فيه القيم الحقيقية
# ============================================================

# === Clerk Auth (مطلوب) ===
# احصل عليه من: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# === Supabase (مطلوب) ===
# احصل عليه من: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Backend API URL (مطلوب في Production) ===
# لو البيكاند على Cloudflare Workers:
VITE_API_URL=https://your-worker.your-subdomain.workers.dev
# لو شغال محلياً:
# VITE_API_URL=http://localhost:8787
